# SelfAware — copy to .env at the repo root. Every value is optional; the
# backend boots (and `make demo-mock` fully demos) with NONE of these set.

# ---- model (ONE switch; any pydantic-ai model string) ----
SELFAWARE_MODEL=anthropic:claude-sonnet-5
# SELFAWARE_AUTHOR_MODEL=            # optional override for the driver author only
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=                    # optional: enables memory-server semantic search

# ---- Crusoe inference (OpenAI-compatible; `crusoe:<model>` model string) ----
# To run everything on Crusoe instead of Anthropic:
#   SELFAWARE_MODEL=crusoe:moonshotai/Kimi-K2.6
#   CRUSOE_API_KEY=your-crusoe-key
# CRUSOE_API_KEY=
# SELFAWARE_CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1/   # override only for a proxy/region

# ---- board ----
SELFAWARE_MOCK_BOARD=false           # true => MockBoard everywhere (explicit, never silent)
SELFAWARE_MOCK_AUTHOR=false          # true => canned driver outputs (keyless demo loop)
SELFAWARE_BOARD_PORT=auto            # auto => glob /dev/cu.usbmodem* ; or an explicit stable path
SELFAWARE_EXEC_TIMEOUT_S=8.0
SELFAWARE_MAX_ATTEMPTS=4

# ---- optional services (backend degrades gracefully when absent) ----
SELFAWARE_MEMORY_URL=http://localhost:8100
SELFAWARE_OTLP_ENDPOINT=http://localhost:4318

# ---- frontend (Vite reads VITE_* at build/dev time) ----
VITE_WS_URL=ws://localhost:8000/ws
VITE_MOCK=0                          # 1 => FixturePlayer instead of the real WS
